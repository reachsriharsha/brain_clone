# =============================================================================
# brain_clone — Environment Configuration
#
# Copy this file to .env and customize for your setup:
#   cp .env.example .env
#
# Both install.sh and sync-claude-sessions.sh read from .env
# =============================================================================

# --- Vault -------------------------------------------------------------------
# Root path for the Obsidian vault (all collections live under this)
VAULT_PATH="$HOME/vault"

# --- Claude Code -------------------------------------------------------------
# Where Claude Code stores session JSONL files
CLAUDE_SESSIONS_DIR="$HOME/.claude/projects"

# Where to install the session sync script
SYNC_SCRIPT_PATH="$HOME/.local/bin/sync-claude-sessions.sh"

# Claude Code hooks config file
HOOKS_FILE="$HOME/.claude/hooks.json"

# Claude Code skills directory for /recall
SKILL_DIR="$HOME/.claude/skills/recall"

# --- MCP Server --------------------------------------------------------------
# Name for the MCP server (used in client configs)
MCP_SERVER_NAME="qmd"

# Port for MCP HTTP daemon
MCP_HTTP_PORT=8181

# --- Node.js ------------------------------------------------------------------
# Minimum Node.js version required by QMD
NODE_MIN_VERSION=22
